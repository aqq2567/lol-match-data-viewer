{
  "说明": "LCU API 可获取的全部数据字段清单 —— 按数据层级组织，标注了当前是否已在前端展示",
  "总计可聚合指标": "Stats 层约 90+ 个可聚合数值字段，当前 AnalysisView 仅展示了其中 27 个",

  "══════════════════════════════════════════════════": "",
  "1. LCU 连接信息 (LcuConnectionInfo)": {
    "_来源": "PowerShell 进程检测 → findLolClient()",
    "port": { "类型": "number", "注释": "LCU API 端口号，如 57313" },
    "authToken": { "类型": "string", "注释": "remoting-auth-token，用于 Basic Auth" },
    "pid": { "类型": "number", "注释": "LeagueClientUx.exe 进程 ID" },
    "region": { "类型": "string", "注释": "区域，如 TENCENT / GARENA" },
    "rsoPlatformId": { "类型": "string", "注释": "RSO 平台 ID" }
  },

  "══════════════════════════════════════════════════": "",
  "2. 召唤师信息 (SummonerInfo)": {
    "_来源": "/lol-summoner/v1/current-summoner",
    "puuid": { "类型": "string", "注释": "玩家全局唯一 ID" },
    "name": { "类型": "string", "注释": "显示名称 (displayName)" },
    "level": { "类型": "number", "注释": "召唤师等级" },
    "region": { "类型": "string", "注释": "区域" },
    "platform": { "类型": "string", "注释": "平台 ID" },
    "profileIconId": { "类型": "number", "注释": "头像 ID" }
  },

  "══════════════════════════════════════════════════": "",
  "3. 段位数据 (RankedData)": {
    "_来源": "/lol-ranked/v1/current-ranked-stats",
    "highest_current_tier": { "类型": "string", "注释": "当前赛季最高段位，如 GOLD" },
    "highest_previous_tier": { "类型": "string", "注释": "上赛季最高段位" },
    "queues": {
      "类型": "Record<string, QueueRanked>",
      "注释": "各队列段位详情，key 为队列类型",
      "字段": {
        "tier": { "类型": "string", "注释": "段位，如 GOLD / PLATINUM" },
        "division": { "类型": "string", "注释": "段位等级，如 I / II / III / IV" },
        "league_points": { "类型": "number", "注释": "胜点" },
        "wins": { "类型": "number", "注释": "胜场" },
        "losses": { "类型": "number", "注释": "负场" },
        "win_rate": { "类型": "number", "注释": "胜率(已计算)" }
      }
    }
  },

  "══════════════════════════════════════════════════": "",
  "4. 对局列表响应 (MatchHistory → Games)": {
    "_来源": "/lol-match-history/v1/products/lol/{puuid}/matches?begIndex=0&endIndex=99",
    "accountId": { "类型": "number", "注释": "账号 ID" },
    "platformId": { "类型": "string", "注释": "平台 ID" },
    "games": {
      "gameCount": { "类型": "number", "注释": "对局总数（LCU API 单玩家上限 ~200 场，默认缓存 ~20 场）" },
      "gameIndexBegin": { "类型": "number", "注释": "返回的起始索引" },
      "gameIndexEnd": { "类型": "number", "注释": "返回的结束索引" },
      "gameBeginDate": { "类型": "string", "注释": "最早对局日期" },
      "gameEndDate": { "类型": "string", "注释": "最晚对局日期" },
      "games": { "类型": "Game[]", "注释": "对局数组(仅摘要，不含 stats 详情)" }
    }
  },

  "══════════════════════════════════════════════════": "",
  "5. 单场对局摘要 (Game)": {
    "_来源": "match-history 列表中的单条(摘要) / game-detail 接口(完整)",
    "gameId": { "类型": "number", "注释": "对局唯一 ID" },
    "gameCreation": { "类型": "number", "注释": "对局创建时间戳(毫秒)" },
    "gameCreationDate": { "类型": "string", "注释": "对局创建日期" },
    "gameDuration": { "类型": "number", "注释": "游戏时长(秒)" },
    "gameMode": { "类型": "string", "注释": "游戏模式，如 CLASSIC / ARAM / PRACTICETOOL" },
    "gameType": { "类型": "string", "注释": "游戏类型，如 MATCHED_GAME" },
    "gameVersion": { "类型": "string", "注释": "游戏版本号" },
    "mapId": { "类型": "number", "注释": "地图 ID，11=召唤师峡谷" },
    "queueId": { "类型": "number", "注释": "队列 ID，可映射到队列名称" },
    "seasonId": { "类型": "number", "注释": "赛季 ID" },
    "platformId": { "类型": "string", "注释": "平台 ID" },
    "endOfGameResult": { "类型": "string", "注释": "游戏结束结果" }
  },

  "══════════════════════════════════════════════════": "",
  "6. 队伍数据 (Team)": {
    "_来源": "Game.teams[] — blue_team / red_team",
    "_说明": "当前代码中 TeamData 已提取，但只在 GameDetail 页面的队伍面板中使用，AnalysisView 中未暴露",
    "team_id": { "类型": "number", "注释": "队伍 ID，100=蓝方, 200=红方" },
    "win": { "类型": "boolean", "注释": "是否获胜" },
    "bans": { "类型": "any[]", "注释": "禁用英雄列表" },
    "baron_kills": { "类型": "number", "注释": "纳什男爵击杀数" },
    "dragon_kills": { "类型": "number", "注释": "巨龙击杀数" },
    "rift_herald_kills": { "类型": "number", "注释": "峡谷先锋击杀数" },
    "vilemaw_kills": { "类型": "number", "注释": "卑鄙之喉击杀数(3v3地图)" },
    "horde_kills": { "类型": "number", "注释": "虫群击杀数" },
    "tower_kills": { "类型": "number", "注释": "防御塔摧毁数" },
    "inhibitor_kills": { "类型": "number", "注释": "水晶摧毁数" },
    "first_blood": { "类型": "boolean", "注释": "是否拿下一血" },
    "first_tower": { "类型": "boolean", "注释": "是否拿下一塔" },
    "first_inhibitor": { "类型": "boolean", "注释": "是否拿下一水晶" },
    "first_baron": { "类型": "boolean", "注释": "是否拿下第一条男爵" },
    "first_dragon": { "类型": "boolean", "注释": "是否拿下第一条龙" }
  },

  "══════════════════════════════════════════════════": "",
  "7. 参与者基础信息 (Participant + Player)": {
    "_来源": "Game.participants[] + Game.participantIdentities[]",
    "participantId": { "类型": "number", "注释": "参与者 ID(对局内唯一)" },
    "championId": { "类型": "number", "注释": "使用的英雄 ID" },
    "teamId": { "类型": "number", "注释": "队伍 ID，100=蓝方, 200=红方" },
    "spell1Id": { "类型": "number", "注释": "召唤师技能1 ID" },
    "spell2Id": { "类型": "number", "注释": "召唤师技能2 ID" },
    "highestAchievedSeasonTier": { "类型": "string", "注释": "该玩家本赛季最高段位" },
    "puuid": { "类型": "string", "注释": "玩家 PUUID" },
    "accountId": { "类型": "number", "注释": "账号 ID" },
    "summonerId": { "类型": "number", "注释": "召唤师 ID" },
    "summonerName": { "类型": "string", "注释": "召唤师名称" },
    "gameName": { "类型": "string", "注释": "游戏内名称(Riot ID)" },
    "tagLine": { "类型": "string", "注释": "标签行(Riot ID 后缀)" },
    "profileIcon": { "类型": "number", "注释": "头像图标 ID" },
    "platformId": { "类型": "string", "注释": "平台 ID" },
    "currentPlatformId": { "类型": "string", "注释": "当前平台 ID" },
    "currentAccountId": { "类型": "number", "注释": "当前账号 ID" },
    "matchHistoryUri": { "类型": "string", "注释": "历史记录 URI" }
  },

  "══════════════════════════════════════════════════": "",
  "8. 时间线数据 (Timeline)": {
    "_来源": "Participant.timeline — 分阶段统计(0-10min, 10-20min, 20-30min, 30min+)",
    "_说明": "当前代码完全未提取！extractStatsFull() 没有处理 timeline 字段",
    "participantId": { "类型": "number", "注释": "参与者 ID" },
    "lane": { "类型": "string", "注释": "路线，如 TOP / MID / BOTTOM / JUNGLE" },
    "role": { "类型": "string", "注释": "角色，如 SOLO / DUO / NONE" },
    "creepsPerMinDeltas": {
      "类型": "Record<string, number>",
      "注释": "分均补刀(分阶段)，key 如 '0-10' / '10-20'",
      "可为指标": "✅ 各阶段补刀效率"
    },
    "csDiffPerMinDeltas": {
      "类型": "Record<string, number>",
      "注释": "补刀差(分阶段)，与对手的补刀差值",
      "可为指标": "✅ 对线压制力"
    },
    "goldPerMinDeltas": {
      "类型": "Record<string, number>",
      "注释": "分均金币(分阶段)",
      "可为指标": "✅ 经济曲线"
    },
    "xpPerMinDeltas": {
      "类型": "Record<string, number>",
      "注释": "分均经验(分阶段)",
      "可为指标": "✅ 经验获取效率"
    },
    "xpDiffPerMinDeltas": {
      "类型": "Record<string, number>",
      "注释": "经验差(分阶段)",
      "可为指标": "✅ 等级压制"
    },
    "damageTakenPerMinDeltas": {
      "类型": "Record<string, number>",
      "注释": "分均承伤(分阶段)",
      "可为指标": "✅ 承伤节奏"
    },
    "damageTakenDiffPerMinDeltas": {
      "类型": "Record<string, number>",
      "注释": "承伤差(分阶段)",
      "可为指标": "✅ 被针对程度"
    }
  },

